:{$PORT} {
    root * .
    file_server

    header {
        # Custom headers to override default restrictive CSP and allow blob: / data: for HLS streaming
        Content-Security-Policy "default-src 'self' https: *; img-src 'self' data: https: *; style-src 'self' 'unsafe-inline' https: *; script-src 'self' 'unsafe-inline' https: *; font-src 'self' data: https: *; connect-src 'self' blob: data: https: *; media-src 'self' blob: data: https: *; object-src 'none'; frame-src 'self' https: *;"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-Content-Type-Options "nosniff"
        X-Xss-Protection "1; mode=block"
        Access-Control-Allow-Origin "*"
    }
}
